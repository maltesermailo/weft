<?xml version="1.0" encoding="UTF-8"?>
<!-- Merged into the macOS bundle's Info.plist by tauri-build. The microphone and
     camera usage strings are required for the webview's getUserMedia to prompt on
     macOS (§16 voice + video). -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>NSMicrophoneUsageDescription</key>
    <string>Weft uses your microphone for voice channels.</string>
    <key>NSCameraUsageDescription</key>
    <string>Weft uses your camera for video in voice channels.</string>
  </dict>
</plist>
