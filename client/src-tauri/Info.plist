<?xml version="1.0" encoding="UTF-8"?>
<!-- Merged into the macOS bundle's Info.plist by tauri-build. The microphone
     usage string is required for the webview's getUserMedia to prompt on macOS
     (§16 voice). -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>NSMicrophoneUsageDescription</key>
    <string>Weft uses your microphone for voice channels.</string>
  </dict>
</plist>
