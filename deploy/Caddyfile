# Caddy fronts the WEFT *HTTP* surface with automatic Let's Encrypt: the
# /.well-known/weft discovery doc (§10.2), the /admin panel, and — with the P3
# web embed (`[listen] web = true`, weftd built `--features web-ui`) — the
# browser client at / plus its same-origin WebSocket at /ws.
#
# IMPORTANT: QUIC is NOT proxied here. weftd's native transport is QUIC (UDP +
# TLS 1.3, end-to-end) — a reverse proxy cannot terminate it. weftd holds the
# QUIC certificate itself: either built-in ACME (`[acme]` in weftd.toml) or a
# shared cert file (see deploy/README.md). Caddy only handles TCP/HTTP.

weft.example.com {
	# Proxy the whole HTTP surface to weftd's HTTP listener
	# ([listen] http = "127.0.0.1:8080"). This one rule covers the SPA (/),
	# the wasm bundle (/wasm/*), /.well-known/weft, /admin, AND the WebSocket
	# at /ws — Caddy's reverse_proxy upgrades WebSocket connections
	# transparently, so no extra config is needed for /ws.
	reverse_proxy 127.0.0.1:8080
}

# If you'd rather NOT serve the browser client here (API/well-known only), use
# path-scoped handles instead — but then /ws must still be routed to weftd or the
# web client can't connect:
#
# weft.example.com {
# 	handle /.well-known/weft { reverse_proxy 127.0.0.1:8080 }
# 	handle /admin*           { reverse_proxy 127.0.0.1:8080 }
# 	handle /ws               { reverse_proxy 127.0.0.1:8080 }  # WebSocket
# 	handle /wasm/*           { reverse_proxy 127.0.0.1:8080 }
# 	handle /                 { reverse_proxy 127.0.0.1:8080 }  # SPA entry
# 	handle { respond 404 }
# }
