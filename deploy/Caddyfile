# Caddy fronts the WEFT + LiveKit HTTP/WebSocket surfaces with automatic Let's
# Encrypt (needs public DNS for these names + ports 80/443 reachable). Edit the
# two site addresses below to your domains — they MUST MATCH deploy/weft.toml.
#
# QUIC is NOT proxied (a reverse proxy can't terminate weftd's UDP+TLS QUIC).
# weftd holds the QUIC cert itself — it reads Caddy's cert from the shared
# `caddy_data` volume (see the [tls] block in weft.toml). LiveKit's RTC *media*
# (UDP 50000-50020) is also direct, not proxied — only its signaling is here.

# The weftd HTTP surface: the embedded web client (/), same-origin /ws,
# /.well-known/weft (§10.2), /media (§13). reverse_proxy upgrades WebSockets
# transparently, so /ws needs no extra config.
weft.example.com {
	reverse_proxy weftd:8081
}

# LiveKit signaling (browsers connect wss://livekit.<domain> — this MUST MATCH
# [voice.livekit] url in weft.toml). Media rides UDP direct to the host.
livekit.weft.example.com {
	reverse_proxy livekit:7880
}
